# Local development overrides. Production values are injected by Railway.
APP_ENV=development
SITE_URL=http://localhost:8000

# Railway provides these in production; set them locally only if you want
# the footer meta to show real values during dev.
# RAILWAY_GIT_COMMIT_SHA=
# RAILWAY_DEPLOYMENT_ID=

